---
export const prerender = false
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="/src/styles/global.css">
    <script src="/src/scripts/index.js"></script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Sans+3">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200">
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro</title>
  </head>
  <body>
    <main>
      <header class="panel">
        <div class="menu">
          <div class="item">
            <span class="label">
              <span class="before">Drawing: </span>
              <span data-insert="current-title"></span>
            </span>
            <button class="icon-btn" data-do="close-drawing">
              <input type="checkbox">
              <i class="material-symbols-outlined">delete</i>
            </button>
            <button class="icon-btn" data-do="save-drawing">
              <i class="material-symbols-outlined">check</i>
            </button>
          </div>
        </div>
      </header>
      <div class="easel">
        <img src="" id="refImage">
        <!-- <canvas></canvas> -->
      </div>
    </main>
    <aside class="panel">
      <div class="menu" id="pics">
        <div class="item">
          <span class="label">Pictures</span>
          <button class="icon-btn" data-do="add-picture">
            <i class="material-symbols-outlined">add</i>
          </button>
        </div>
      </div>
      <div class="menu" id="videos">
        <div class="item">
          <span class="label">Tutorials</span>
          <button class="icon-btn">
            <i class="material-symbols-outlined">search</i>
          </button>
        </div>
      </div>
      <div class="menu" id="camera">
        <div class="item">
          <span class="label">Camera</span>
          <button class="icon-btn">
            <i class="material-symbols-outlined">photo_camera</i>
          </button>
        </div>
      </div>
    </aside>
    
    <template id="template-menu-item">
      <div class="item" data-item>
        <div class="spacer"></div>
        <span class="label" data-insert="new-title"></span>
        <button class="icon-btn" data-do="open-pic">
          <i class="material-symbols-outlined">arrow_forward</i>
        </button>
      </div>
    </template>
  </body>
</html>