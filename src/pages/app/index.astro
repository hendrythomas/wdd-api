---
export const prerender = false
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="./styles/app.css">
    <script src="/src/scripts/app.js"></script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Sans+3">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200">
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro</title>
  </head>
  <body>
    <main>
      <header class="panel">
        <div class="menu">
          <div class="item">
            <span class="label">
              <span class="before">Drawing: </span>
              <span data-insert="current-title"></span>
            </span>
            <button class="icon-btn" data-do="delete-drawing">
              <i class="material-symbols-outlined">delete</i>
            </button>
            <button class="icon-btn" data-do="close-drawing">
              <i class="material-symbols-outlined">close</i>
            </button>
            <button class="icon-btn" data-do="save-drawing">
              <i class="material-symbols-outlined">check</i>
            </button>
          </div>
        </div>
      </header>
      <div class="easel">
        <canvas id="canvas"></canvas>
        <div class="ref-container">
          <img src="" id="refImage">
        </div>
      </div>
    </main>
    <aside class="panel">
      <div class="menu" id="pics">
        <div class="item">
          <span class="label">Pictures</span>
          <button class="icon-btn" popovertarget="popover-select-add-pic">
            <i class="material-symbols-outlined">add</i>
          </button>
        </div>
      </div>
      <div class="menu" id="videos">
        <div class="item">
          <span class="label">Tutorials</span>
          <button class="icon-btn">
            <i class="material-symbols-outlined">search</i>
          </button>
        </div>
      </div>
      <div class="menu" id="camera">
        <div class="item">
          <span class="label">Camera</span>
          <label class="icon-btn" data-do="upload-ref">
            <input type="file" accept="image/png, image/jpeg, image/webp">
            <i class="material-symbols-outlined">upload</i>
          </label>
          <button class="icon-btn" data-do="enable-webcam" popovertarget="popover-take-photo">
            <i class="material-symbols-outlined">photo_camera</i>
          </button>
        </div>
      </div>
    </aside>
    <div class="popover" id="popover-select-add-pic" popover>
      <h3>Select a picture to add</h3>
      <select id="select-add-pic" name="pets">
        <option value="">--Choose--</option>
        <option value="dog">Duck</option>
        <option value="cat">Dog</option>
        <option value="duck">Cat</option>
      </select>
    </div>
    <div class="popover" id="popover-take-photo" popover>
      <h3>Take a photo</h3>
      <video class="webcam" id="webcam-video" autoplay></video>
      <button class="icon-btn" data-do="take-photo">
        <i class="material-symbols-outlined">photo_camera</i>
      </button>
    </div>
    
    <template id="template-menu-item">
      <div class="item" data-item>
        <div class="spacer"></div>
        <span class="label" data-insert="new-title"></span>
        <button class="icon-btn" data-do="open-drawing">
          <i class="material-symbols-outlined">arrow_forward</i>
        </button>
      </div>
    </template>
  </body>
</html>
